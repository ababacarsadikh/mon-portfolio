    <div class="sidebar-card">
        <h3>Commandes clés</h3>
        <div style="font-family:'JetBrains Mono',monospace;font-size:0.78em;color:#8888aa;line-height:2.2;">
            <div style="color:var(--primary);">pip install ultralytics</div>
